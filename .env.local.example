# .env.local.example
# Copy this file to .env.local and fill in real values. Never commit .env.local.

# ── Supabase ────────────────────────────────────────────────────────────────
# Found in Supabase dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
# Service role key — server-only, used by the Razorpay webhook to bypass RLS.
# NEVER expose this with the NEXT_PUBLIC_ prefix or in client code.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Razorpay ─────────────────────────────────────────────────────────────────
# Found in Razorpay dashboard → Settings → API Keys
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-key-secret
# Set after creating a webhook in Razorpay dashboard → Settings → Webhooks
# pointed at https://yourdomain.com/api/razorpay/webhook, subscribed to
# the "payment.captured" event.
RAZORPAY_WEBHOOK_SECRET=your-webhook-secret

# ── Anthropic (cover letter generation) ─────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxx
